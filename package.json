{
  "name": "proto-familiar",
  "version": "0.3.9-alpha",
  "description": "Lightweight LLM frontend for z.ai and NanoGPT",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "prestart": "node scripts/ensure-unruh-deps.mjs && node scripts/ensure-port-free.mjs",
    "start": "node server.js",
    "predev": "node scripts/ensure-unruh-deps.mjs && node scripts/ensure-port-free.mjs",
    "dev": "node --watch server.js",
    "test": "node --test tests/*.test.mjs",
    "import-entity": "node scripts/import-entity.js",
    "import-tome": "node scripts/import-tome.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
