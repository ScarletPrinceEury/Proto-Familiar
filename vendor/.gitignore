# vendor/ — third-party apps the Familiar runs.
#
# SearXNG is NOT committed (its ~970-file source bloated the repo). Instead the
# managed backend FETCHES it on first enable, pinned to a commit SHA, and
# re-applies the patches under vendor/searxng-patches/ (which ARE tracked). So
# we ignore the whole fetched source tree but keep the patches + this file.
searxng/
# Never commit build artifacts / venvs even if the dir is force-added.
**/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
